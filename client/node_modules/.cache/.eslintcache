,"messages":"31","errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"32","usedDeprecatedRules":"20"},{"filePath":"33","messages":"34","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"35","messages":"36","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/allisonchen/Desktop/filmdiary/client/src/index.js",[],["37","38"],"/Users/allisonchen/Desktop/filmdiary/client/src/App.js",["39","40"],"import React, { useReducer, useEffect } from \"react\";\nimport \"bootstrap/dist/css/bootstrap.min.css\";\n\n// We use Route in order to define the different routes of our application\nimport { Route, Routes } from \"react-router-dom\";\n\n// We import all the components we need in our app\nimport Navbar from \"./components/navbar\";\nimport RecordList from \"./components/recordList\";\nimport Edit from \"./components/edit\";\nimport Create from \"./components/create\";\nimport Search from \"./components/search/search\";\nimport MoviePage from \"./components/moviePage/moviePage\";\n\n\nconst App = () => {   \n  return (\n    <div>\n      <Navbar />\n      <div style={{ margin: 20 }}>\n        <Routes>\n          <Route exact path=\"/\" element={<RecordList />} />\n          <Route path=\"/search\" element={<Search />} />\n          {/* <Route path=\"/moviePage\" element={<MoviePage />} /> */}\n          {/* <Route path='/moviePage/:id' component={MoviePage} /> */}\n          <Route path=\"/movies/:id\" render={(props) => <MoviePage {...props}/>} />\n          <Route path=\"/edit/:id\" element={<Edit />} />\n          <Route path=\"/create\" element={<Create />} />\n        </Routes>\n      </div>\n    </div>\n  );\n};\n\nexport default App;\n","/Users/allisonchen/Desktop/filmdiary/client/src/components/edit.js",[],"/Users/allisonchen/Desktop/filmdiary/client/src/components/create.js",[],"/Users/allisonchen/Desktop/filmdiary/client/src/components/recordList.js",[],"/Users/allisonchen/Desktop/filmdiary/client/src/components/navbar.js",["41","42","43"],"import React from \"react\";\n\n// We import bootstrap to make our application look better.\nimport \"bootstrap/dist/css/bootstrap.css\";\n\n// We import NavLink to utilize the react router.\nimport { NavLink } from \"react-router-dom\";\n\nimport logo from \"./logo.png\";\n\nimport { BrowserRouter as Route, Link } from \"react-router-dom\";\n\n// Here, we display our Navbar\nexport default function Navbar() {\n  return (\n    <div>\n      <nav className=\"navbar navbar-expand-lg navbar-light bg-light\">\n        <NavLink className=\"navbar-brand\" to=\"/\">\n        <a><img src={logo} width=\"25\" height=\"25\" alt=\"Film Diary\"/></a> FILM DIARY\n        </NavLink>\n        <button\n          className=\"navbar-toggler\"\n          type=\"button\"\n          data-toggle=\"collapse\"\n          data-target=\"#navbarSupportedContent\"\n          aria-controls=\"navbarSupportedContent\"\n          aria-expanded=\"false\"\n          aria-label=\"Toggle navigation\"\n        >\n          <span className=\"navbar-toggler-icon\"></span>\n        </button>\n\n        <div class=\"collapse navbar-collapse justify-content-center\" id=\"navbarNav\">\n            <ul class=\"navbar-nav\">\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"/\">diary</a>\n          </li>\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"/\">lists</a>\n          </li>\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"/search\">search</a>\n          </li>\n        </ul>\n        </div>\n\n        <div className=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n          <ul className=\"navbar-nav ml-auto\">\n            <li className=\"nav-item\">\n              <NavLink className=\"nav-link\" to=\"/create\">\n                + LOG\n              </NavLink>\n            </li>\n          </ul>\n        </div>\n      </nav>\n    </div>\n  );\n}\n","/Users/allisonchen/Desktop/filmdiary/client/src/components/search/search.js",[],"/Users/allisonchen/Desktop/filmdiary/client/src/components/moviePage/moviePage.js",[],{"ruleId":"44","replacedBy":"45"},{"ruleId":"46","replacedBy":"47"},{"ruleId":"48","severity":1,"message":"49","line":1,"column":17,"nodeType":"50","messageId":"51","endLine":1,"endColumn":27},{"ruleId":"48","severity":1,"message":"52","line":1,"column":29,"nodeType":"50","messageId":"51","endLine":1,"endColumn":38},{"ruleId":"48","severity":1,"message":"53","line":11,"column":27,"nodeType":"50","messageId":"51","endLine":11,"endColumn":32},{"ruleId":"48","severity":1,"message":"54","line":11,"column":34,"nodeType":"50","messageId":"51","endLine":11,"endColumn":38},{"ruleId":"55","severity":1,"message":"56","line":19,"column":9,"nodeType":"57","endLine":19,"endColumn":12},"no-native-reassign",["58"],"no-negated-in-lhs",["59"],"no-unused-vars","'useReducer' is defined but never used.","Identifier","unusedVar","'useEffect' is defined but never used.","'Route' is defined but never used.","'Link' is defined but never used.","jsx-a11y/anchor-is-valid","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","JSXOpeningElement","no-global-assign","no-unsafe-negation"]